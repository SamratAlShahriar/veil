# .pubignore — files excluded from pub.dev published package

# IDE
.idea/
.vscode/
*.iml

# macOS
.DS_Store
**/.DS_Store

# Dart tool
.dart_tool/
example/.dart_tool/

# CI
.github/

# Coverage
coverage/

# Build outputs
build/

# Screenshots — used in README, not needed in package
screenshots/

# Example platform folders — not needed in published package
example/android/
example/ios/
example/macos/
example/linux/
example/windows/
example/web/

# Example generated files
example/pubspec.lock
example/README.md
example/analysis_options.yaml